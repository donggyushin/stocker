{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tests-writer-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/src-first-requires-tests.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-sync-check.sh",
            "timeout": 10,
            "statusMessage": "문서 동기화 체크"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/test-coverage-check.sh",
            "timeout": 10,
            "statusMessage": "단위 테스트 커버리지 체크"
          }
        ]
      }
    ]
  }
}
