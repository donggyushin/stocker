# 실제 값을 채우려면 이 파일을 .env로 복사한 뒤 사용한다.
# .env 는 .gitignore 로 추적이 막혀 있으므로 절대 커밋되지 않아야 한다.

# ─────────────────────────────────────────────
# 실행 환경 (paper = 모의투자, live = 실전)
# Phase 0 ~ Phase 3 까지는 반드시 paper 로 둔다.
# KIS_KEY_ORIGIN 은 아래 KIS_APP_KEY/SECRET 의 발급 출처 — KIS_ENV 와 일치해야 함
# (모의·실전 키 모두 36자라 길이로 식별 불가하므로 사용자가 명시).
# ─────────────────────────────────────────────
KIS_ENV=paper
KIS_KEY_ORIGIN=paper

# ─────────────────────────────────────────────
# 한국투자증권 KIS Developers
# - HTS_ID: 한투증권 HTS/MTS 로그인 아이디
# - APP_KEY: 36자, KIS Developers 모의투자 발급분
# - APP_SECRET: 180자, KIS Developers 모의투자 발급분
# - ACCOUNT_NO: 모의 계좌번호 "XXXXXXXX-XX" (8자리-상품코드2자리)
# ─────────────────────────────────────────────
KIS_HTS_ID=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# ─────────────────────────────────────────────
# KIS 실전(live) 키 — 시세 전용 하이브리드 패턴 (선택)
# paper 도메인에 시세 API 가 없어 `RealtimeDataStore` 는 실전 APP_KEY 로 real
# 도메인을 호출한다. 주문·잔고는 위 paper 키, 시세·WebSocket 은 이 실전 키.
#
# HTS_ID 는 paper/실전 동일하므로 위 `KIS_HTS_ID` 를 공유 (실전 전용 ID 필드 없음).
# ACCOUNT_NO 는 paper/실전이 다른 계좌이므로 실전 계좌번호를 별도로 입력한다 —
# 실전 APP_KEY 는 등록된 실전 계좌와 소유자 일치 검증이 있어 paper 계좌번호로는
# 인증이 거부된다.
#
# 3종 all-or-none — 부분 입력은 Settings 검증에서 실패.
# 발급 절차: KIS Developers 포털 → 앱 관리 → "실전투자" 앱 신규 신청
#           → 사용 IP 등록(현재 공인 IP) → 승인 후 APP_KEY/SECRET 발급.
# 미설정 시 healthcheck.py 는 실시간 현재가 체크를 SKIP 한다 (Phase 3 착수 전
# 반드시 발급 완료 필요 — 모의투자 자동 실행에 실시간 체결가가 필수).
# ─────────────────────────────────────────────
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=

# ─────────────────────────────────────────────
# Telegram 알림
# - BOT_TOKEN: @BotFather 가 발급한 HTTP API 토큰
# - CHAT_ID: getUpdates 로 확인한 본인 채팅 id (정수)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
